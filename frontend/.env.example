# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local.

# --- Sanity (public) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# --- Sanity write token (Editor role) ---
# Generate at sanity.io/manage → API → Tokens → Add API Token
# Required by:
#   - scripts/seed-technologies.ts
#   - scripts/import-from-django.ts
#   - scripts/sync-publications.ts
#   - src/app/api/cron/sync-publications/route.ts
SANITY_WRITE_TOKEN=

# --- SerpAPI key ---
# Get one at serpapi.com. Required by publication sync.
SERPAPI_KEY=

# --- Cron secret ---
# Any random high-entropy string. Required for the Vercel Cron route to
# authenticate itself. Set the same value in Vercel → Project → Env Vars.
CRON_SECRET=
